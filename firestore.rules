rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USER PROFILES ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;

      match /friends/{friendUid} {
        allow read:   if request.auth.uid == uid;
        allow write:  if request.auth != null;
        allow delete: if request.auth.uid == uid
                      || request.auth.uid == friendUid;
      }
    }

    // ── ROOMS ──────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.hostUid == request.auth.uid
                    && request.resource.data.status == 'waiting';

      allow update: if request.auth != null
                    && (
                      // Existing participants update game state
                      isParticipant(resource.data, request.auth.uid)
                      ||
                      // New player joining a waiting room
                      (
                        resource.data.status == 'waiting'
                        && request.resource.data.status == 'waiting'
                        && request.resource.data.hostUid == resource.data.hostUid
                        && request.auth.uid in request.resource.data.playerUids
                        && request.resource.data.playerUids.size() == resource.data.playerUids.size() + 1
                      )
                    );

      allow delete: if request.auth != null
                    && resource.data.hostUid == request.auth.uid;

      // Players subcollection
      match /players/{index} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ── ALL-TIME LEADERBOARD ───────────────────────────────────────
    match /leaderboard/allTime/scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 1600
                    && request.resource.data.keys().hasAll(['uid','displayName','score','playedAt']);
      allow update, delete: if false;
    }

    // ── WEEKLY LEADERBOARD ─────────────────────────────────────────
    match /weeklyScores/{week}/scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 1600
                    && request.resource.data.keys().hasAll(['uid','displayName','score','playedAt']);
      allow update, delete: if false;
    }

    // ── FRIEND CODES ───────────────────────────────────────────────
    match /friendCodes/{code} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── MATCHMAKING QUEUE ──────────────────────────────────────────
    match /matchmaking/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth.uid == uid
                    && request.resource.data.status == 'waiting'
                    && request.resource.data.keys().hasAll(['uid','displayName','status','joinedAt']);
      allow update: if request.auth.uid == uid
                    || request.auth != null;
      allow delete: if request.auth != null;
    }

  } // end match /databases/{database}/documents

  // ── HELPERS ────────────────────────────────────────────────────────
  function isParticipant(data, uid) {
    return data.hostUid == uid
      || (data.keys().hasAll(['playerUids']) && uid in data.playerUids);
  }

} // end service cloud.firestore