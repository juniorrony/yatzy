rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USER PROFILES ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['displayName','gamesPlayed','highScore','totalScore'])
                    && request.resource.data.gamesPlayed == 0
                    && request.resource.data.highScore == 0
                    && request.resource.data.totalScore == 0;
      allow update: if request.auth.uid == uid;

      // Friends subcollection
      match /friends/{friendUid} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.uid == uid;
      }
    }

    // ── ALL-TIME LEADERBOARD ───────────────────────────────────────
    match /leaderboard/allTime/scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 1600
                    && request.resource.data.keys().hasAll(['uid','displayName','score','playedAt']);
      allow update, delete: if false;
    }

    // ── WEEKLY LEADERBOARD ─────────────────────────────────────────
    match /leaderboard/weekly/{week}/scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 1600
                    && request.resource.data.keys().hasAll(['uid','displayName','score','playedAt']);
      allow update, delete: if false;
    }

    // ── WEEKLY WINNERS ARCHIVE ─────────────────────────────────────
    match /leaderboard/weeklyWinners/archive/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── FRIEND CODES (public lookup) ───────────────────────────────
    match /friendCodes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.uid == request.auth.uid;
    }

  }
}